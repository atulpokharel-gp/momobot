# MomoBot Agent Configuration
# Get these credentials from the MomoBot dashboard after creating an agent

# Server connection
SERVER_URL=http://localhost:4000

# Agent credentials (copy from dashboard)
AGENT_API_KEY=bot_your_api_key_here
AGENT_SECRET_KEY=your_secret_key_here

# Agent behavior
HEARTBEAT_INTERVAL=30000
RECONNECT_DELAY=5000
MAX_RECONNECT_ATTEMPTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/momobot.log

# Security: Restrict which commands can be executed
# Leave empty to allow all, or comma-separate allowed commands
ALLOWED_COMMANDS=
# ALLOWED_COMMANDS=ls,dir,echo,ping,ipconfig,whoami

# Max command execution time (ms)
DEFAULT_TIMEOUT=30000

# Working directory for shell commands
SHELL_CWD=
